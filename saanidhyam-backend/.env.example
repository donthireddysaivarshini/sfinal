# === DJANGO SETTINGS ===
# Use 'False' for production
DEBUG=False
# Generate a new key using: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=change_me_to_a_long_random_string
# Comma separated list of domains, e.g., your-site.com,www.your-site.com
ALLOWED_HOSTS=localhost,127.0.0.1
# Comma separated list of trusted origins for forms, e.g., https://your-site.com
CSRF_TRUSTED_ORIGINS=https://your-site.com

# === DATABASE (NEON DB) ===
PGDATABASE=neondb
PGUSER=neondb_user
PGPASSWORD=your_neon_password
PGHOST=ep-cool-frog.aws.neon.tech
PGPORT=5432

# === SECURITY & CORS ===
# The frontend URL. e.g., https://your-frontend-site.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# === RAZORPAY PAYMENT ===
RAZORPAY_KEY_ID=rzp_live_xxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=whsec_xxxxxx

# === CELERY/REDIS (Optional if using Redis) ===
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0